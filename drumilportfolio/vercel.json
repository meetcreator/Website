{
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
        {
            "source": "/(.*)",
            "has": [{ "type": "host", "value": "www.tinmco.com" }],
            "destination": "https://tinmco.com/$1",
            "statusCode": 301
        },
        { "source": "/Business/:path*",       "destination": "/business/:path*",              "statusCode": 301 },
        { "source": "/Archshield/:path*",      "destination": "/archshield/:path*",            "statusCode": 301 },
        { "source": "/procurement_ai/:path*",  "destination": "/procurement/:path*",           "statusCode": 301 },
        { "source": "/procurement_ai",         "destination": "/procurement",                  "statusCode": 301 },
        { "source": "/operations/:path*",      "destination": "/procurement/operations/:path*","statusCode": 301 },
        { "source": "/operations",             "destination": "/procurement/operations",       "statusCode": 301 }
    ],
    "rewrites": [
        { "source": "/portfolio",              "destination": "/portfolio.html" },
        { "source": "/procurement",            "destination": "/procurement/index.html" },

        { "source": "/archshield",             "destination": "/archshield-app/frontend/out" },
        { "source": "/archshield/_next/:path*","destination": "/archshield-app/frontend/out/_next/:path*" },
        { "source": "/archshield/:path*",      "destination": "/archshield-app/frontend/out/:path*" },

        { "source": "/business",              "destination": "/business/out" },
        { "source": "/business/_next/:path*", "destination": "/business/out/_next/:path*" },
        { "source": "/business/:path*",       "destination": "/business/out/:path*" },

        { "source": "/olympiad",              "destination": "/olympiad/out" },
        { "source": "/olympiad/:path*",       "destination": "/olympiad/out/:path*" },

        { "source": "/_next/static/:path*",   "destination": "/archshield-app/frontend/out/_next/static/:path*" },
        { "source": "/favicon.ico",           "destination": "/archshield-app/frontend/out/favicon.ico" },
        { "source": "/dashboard",             "destination": "/archshield-app/frontend/out/dashboard" },
        { "source": "/dashboard/:path*",      "destination": "/archshield-app/frontend/out/dashboard/:path*" },
        { "source": "/login",                 "destination": "/archshield-app/frontend/out/login" },
        { "source": "/signup",                "destination": "/archshield-app/frontend/out/signup" }
    ]
}